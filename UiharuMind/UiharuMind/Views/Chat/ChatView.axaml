<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:viewData="clr-namespace:UiharuMind.ViewModels.ViewData"
             xmlns:loc="clr-namespace:UiharuMind.ViewModels.Markup"
             xmlns:converters="clr-namespace:UiharuMind.ViewModels.Converters"
             xmlns:uiHolder="clr-namespace:UiharuMind.ViewModels.UIHolder"
             xmlns:common="clr-namespace:UiharuMind.Views.Common"
             xmlns:extends="clr-namespace:UiharuMind.Extends"
             mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="620"
             x:Class="UiharuMind.Views.OtherViews.ChatView">

    <UserControl.Resources>
        <converters:UserColumIndexConverter x:Key="UserColumIndexConverter" />
        <converters:UserLeftRightConverter x:Key="UserLeftRightConverter" />
        <converters:MultiConditionBoolOrConverter x:Key="MultiConditionBoolOrConverter" />
        <converters:ModelToBrushConverter x:Key="ModelToBrushConverter" />
    </UserControl.Resources>

    <Design.DataContext>
        <viewData:ChatViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.icon">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.message-action">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="MaxWidth" Value="18" />
            <Setter Property="MaxHeight" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey5}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Width="18"
                            Height="18"
                            CornerRadius="4"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.message-action:pointerover">
            <Setter Property="Background" Value="{DynamicResource SemiGrey2}" />
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey7}" />
        </Style>
        <Style Selector="Border.message-actions">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style Selector="Grid.message-row:pointerover Border.message-actions">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="IsHitTestVisible" Value="True" />
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey5}" />
        </Style>
        <Style Selector="Border.tool-row">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey2}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>
        <Style Selector="Border.message-bubble">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MaxWidth" Value="640" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="TextBox.composer-input">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="TextBox.composer-input:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.composer-input:focus">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.composer-input /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input /template/ Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input:pointerover /template/ Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input:focus /template/ Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input:focus-within /template/ Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="TextBox.composer-input /template/ Panel">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.composer-input:pointerover /template/ Panel">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.composer-input:focus-within /template/ Panel">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource SemiGrey0}">
        <Border Grid.Row="0"
                Padding="14,10"
                BorderBrush="{DynamicResource SemiGrey2}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <StackPanel MinWidth="0">
                    <TextBlock Text="{Binding ChatSession.Name, TargetNullValue={loc:Loc ChatWorkspaceEmpty}}"
                               FontWeight="SemiBold"
                               FontSize="16"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               Foreground="{DynamicResource SemiGrey7}" />
                    <TextBlock Classes="muted"
                               Text="{Binding ChatSession.MemoryTipsName}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="icon" Command="{Binding RegenerateMessageCommand}"
                            IsVisible="{Binding IsVisibleRegenerateButton}">
                        <PathIcon Width="17" Height="17" Data="{StaticResource ArrowRepeatAllRegular}" />
                        <ToolTip.Tip>
                            <TextBlock Text="{loc:Loc RegenerateBtn}" />
                        </ToolTip.Tip>
                    </Button>
                    <StackPanel IsVisible="{Binding IsGenerating}" Orientation="Horizontal" Spacing="8">
                        <u:LoadingIcon IsLoading="{Binding IsGenerating}" />
                        <Button Classes="icon" Command="{Binding StopSendingCommand}">
                            <PathIcon Width="16" Height="16" Data="{StaticResource StopRegular}" />
                            <ToolTip.Tip>
                                <TextBlock Text="{loc:Loc StopGenerating}" />
                            </ToolTip.Tip>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Name="Viewer"
                      Padding="18,18,18,0"
                      u:ScrollTo.Direction="Bottom"
                      BringIntoViewOnFocusChange="False"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      uiHolder:ScrollViewExtensions.ScrollToEnd="{Binding ScrollToEnd}">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding ChatSession.ChatItems}">
                    <ItemsControl.ItemTemplate>
                        <extends:ReuseDataTemplate>
                            <Grid Classes="message-row"
                                  ColumnDefinitions="Auto,*,Auto"
                                  Margin="0,0,0,16"
                                  Background="Transparent">
                                <Ellipse Width="34" Height="34"
                                         Stroke="{DynamicResource SemiGrey2}"
                                         StrokeThickness="1"
                                         VerticalAlignment="Top"
                                         IsVisible="{Binding !IsSystem}"
                                         Grid.Column="{Binding Role, Converter={StaticResource UserColumIndexConverter}, ConverterParameter=3}">
                                    <Ellipse.Fill>
                                        <ImageBrush Source="{Binding Icon}" Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                </Ellipse>

                                <Grid Grid.Column="1"
                                      Margin="10,0"
                                      MinHeight="34"
                                      RowDefinitions="Auto,18"
                                      Background="Transparent"
                                      HorizontalAlignment="{Binding Role, Converter={StaticResource UserLeftRightConverter}}">
                                    <StackPanel HorizontalAlignment="{Binding Role, Converter={StaticResource UserLeftRightConverter}}">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    HorizontalAlignment="{Binding Role, Converter={StaticResource UserLeftRightConverter}}">
                                            <TextBlock Text="{Binding SenderName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SemiGrey7}" />
                                            <TextBlock Classes="muted" Text="{Binding Timestamp}" />
                                        </StackPanel>

                                        <Grid Margin="0,5,0,0"
                                              HorizontalAlignment="{Binding Role, Converter={StaticResource UserLeftRightConverter}}">
                                            <Border
                                                    Classes="message-bubble"
                                                    BorderBrush="{Binding SenderColor}"
                                                    HorizontalAlignment="{Binding Role, Converter={StaticResource UserLeftRightConverter}}">
                                                <Panel HorizontalAlignment="Left">
                                                    <common:SimpleMarkdownViewer
                                                        HorizontalAlignment="Left"
                                                        IsVisible="{Binding !IsImageContent}"
                                                        MarkdownText="{Binding Message}"
                                                        IsThinkingRemove="{Binding DataContext.IsNotShowThinking, ElementName=Viewer}">
                                                        <common:SimpleMarkdownViewer.IsPlaintext>
                                                            <MultiBinding Converter="{StaticResource MultiConditionBoolOrConverter}">
                                                                <Binding Path="IsUser" />
                                                                <Binding Path="!IsDone" />
                                                                <Binding Path="DataContext.IsPlaintext" ElementName="Viewer" />
                                                            </MultiBinding>
                                                        </common:SimpleMarkdownViewer.IsPlaintext>
                                                    </common:SimpleMarkdownViewer>
                                                    <Image IsVisible="{Binding IsImageContent}"
                                                           Source="{Binding MessageImage}"
                                                           MaxWidth="520"
                                                           MaxHeight="360" />
                                                </Panel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>

                                    <Border Classes="message-actions"
                                            Grid.Row="1"
                                            HorizontalAlignment="{Binding Role, Converter={StaticResource UserLeftRightConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <Button Classes="message-action" Command="{Binding BranchCommand}">
                                                <PathIcon Width="11" Height="11" Data="{StaticResource BranchRegular}" />
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc BranchChatAfterMessage}" />
                                                </ToolTip.Tip>
                                            </Button>
                                            <Button Classes="message-action" Command="{Binding RetryCommand}">
                                                <PathIcon Width="11" Height="11" Data="{StaticResource ArrowRepeatAllRegular}" />
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc RetryMessage}" />
                                                </ToolTip.Tip>
                                            </Button>
                                            <Button Classes="message-action" Command="{Binding CopyCommand}">
                                                <PathIcon Width="11" Height="11" Data="{StaticResource CopyRegular}" />
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc Copy}" />
                                                </ToolTip.Tip>
                                            </Button>
                                            <Button Classes="message-action" Command="{Binding EditCommand}">
                                                <PathIcon Width="11" Height="11" Data="{StaticResource EditRegular}" />
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc Edit}" />
                                                </ToolTip.Tip>
                                            </Button>
                                            <Button Classes="message-action" Command="{Binding DeleteCommand}">
                                                <PathIcon Width="11" Height="11" Data="{StaticResource DeleteRegular}" />
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc Delete}" />
                                                </ToolTip.Tip>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </extends:ReuseDataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Height="28" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Margin="14"
                Padding="8"
                Classes="tool-row">
            <Grid RowDefinitions="*,Auto" RowSpacing="4">
                <TextBox Grid.Row="0"
                         Name="InputBox"
                         Classes="composer-input"
                         Text="{Binding InputText, Mode=TwoWay}"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         PlaceholderText="{loc:Loc ChatInputTips}">
                    <TextBox.KeyBindings>
                        <KeyBinding Command="{Binding SendMessageCommand}" Gesture="{Binding SendGesture}" />
                    </TextBox.KeyBindings>
                </TextBox>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button Classes="icon" Command="{Binding ChangeSendModeCommand}">
                            <TextBlock Text="{Binding SenderMode}" FontSize="11" />
                            <ToolTip.Tip>
                                <TextBlock Text="{loc:Loc SendUserDesc}" />
                            </ToolTip.Tip>
                        </Button>
                        <Button Classes="icon" Command="{Binding ChatSession.MemoryEditorCommand}">
                            <PathIcon Width="18" Height="18"
                                      Data="{StaticResource BookStarRegular}"
                                      Foreground="{Binding ChatSession.MemoryData, Converter={StaticResource ModelToBrushConverter}}" />
                            <ToolTip.Tip>
                                <TextBlock Text="{loc:Loc MemoryTips}" />
                            </ToolTip.Tip>
                        </Button>
                        <Button Classes="icon" Command="{Binding ChatSession.MemoryUpdateFileCommand}">
                            <PathIcon Width="18" Height="18"
                                      Data="{StaticResource DocumentAddRegular}"
                                      Foreground="{Binding ChatSession.MemoryFileBrush}" />
                            <ToolTip.Tip>
                                <TextBlock Text="{Binding ChatSession.MemoryFileTips}" />
                            </ToolTip.Tip>
                        </Button>
                        <Button Classes="icon" Command="{Binding ChatSession.MemoryUpdateUrlCommand}">
                            <PathIcon Width="18" Height="18"
                                      Data="{StaticResource GlobeAddRegular}"
                                      Foreground="{Binding ChatSession.MemoryUrlBrush}" />
                            <ToolTip.Tip>
                                <TextBlock Text="{Binding ChatSession.MemoryUrlTips}" />
                            </ToolTip.Tip>
                        </Button>
                        <Button Classes="icon"
                                IsVisible="{Binding IsSurportImage}"
                                Command="{Binding UploadImageCommand}">
                            <PathIcon Width="18" Height="18" Data="{StaticResource ImageRegular}" />
                        </Button>
                        <Button Classes="icon">
                            <PathIcon Width="18" Height="18" Data="{StaticResource Setting}" />
                            <Button.Flyout>
                                <Flyout Placement="Top">
                                    <Border Padding="10"
                                            CornerRadius="8"
                                            Background="{DynamicResource SemiGrey0}"
                                            BorderBrush="{DynamicResource SemiGrey2}"
                                            BorderThickness="1">
                                        <StackPanel Spacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <PathIcon Width="16"
                                                          Height="16"
                                                          VerticalAlignment="Center"
                                                          Data="{StaticResource Setting}" />
                                                <TextBlock Text="{loc:Loc Settings}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SemiGrey7}" />
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource SemiGrey2}" />

                                            <CheckBox Content="{loc:Loc HideThnkingText}"
                                                      IsChecked="{Binding IsNotShowThinking}">
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc HideThnkingTextTips}" />
                                                </ToolTip.Tip>
                                            </CheckBox>

                                            <CheckBox Content="{loc:Loc Plaintext}"
                                                      IsChecked="{Binding IsPlaintext}">
                                                <ToolTip.Tip>
                                                    <TextBlock Text="{loc:Loc ChatPlaintextTooltip}" />
                                                </ToolTip.Tip>
                                            </CheckBox>
                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                            <ToolTip.Tip>
                                <TextBlock Text="{loc:Loc Settings}" />
                            </ToolTip.Tip>
                        </Button>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Classes="icon"
                            IsVisible="{Binding !IsGenerating}"
                            IsEnabled="{Binding InputText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Command="{Binding SendMessageCommand}">
                        <PathIcon Width="18" Height="18" Data="{StaticResource Chat}" />
                        <ToolTip.Tip>
                            <TextBlock Text="{loc:Loc Send}" />
                        </ToolTip.Tip>
                    </Button>

                    <Button Grid.Column="1"
                            Classes="icon"
                            IsVisible="{Binding IsGenerating}"
                            Command="{Binding StopSendingCommand}">
                        <PathIcon Width="18" Height="18" Data="{StaticResource StopRegular}" />
                        <ToolTip.Tip>
                            <TextBlock Text="{loc:Loc StopGenerating}" />
                        </ToolTip.Tip>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
