<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lang="clr-namespace:UiharuMind.Resources.Lang"
             xmlns:loc="clr-namespace:UiharuMind.ViewModels.Markup"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UiharuMind.Views.Chat.ChatPlugins.ChatPlugin_CharacterFuncBtn">

    <Button Content="{loc:Loc EditCharacter}"
            Margin="0,10"
            HorizontalAlignment="Stretch"
            Command="{Binding EditCharacterCommand}" />

</UserControl>