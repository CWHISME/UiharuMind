<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="clr-namespace:UiharuMind.ViewModels"
             xmlns:converters="clr-namespace:UiharuMind.ViewModels.Converters"
             xmlns:controls="clr-namespace:UiharuMind.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UiharuMind.Views.MainView"
             x:DataType="vm:MainViewModel">
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
         to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>
    <UserControl.Resources>
        <vm:IconNameToPathConverter x:Key="IconConverter" />
    </UserControl.Resources>

    <!-- 如果需要模糊 -->
    <!-- Classes.Blur="{Binding MessageService.IsBusy}" -->
    <Panel>
        <Grid
            ColumnDefinitions="Auto, *"
            RowDefinitions="Auto, *">
            <!--模糊-->
            <Grid.Styles>
                <Style Selector="Grid.Blur">
                    <Setter Property="Effect" Value="blur(20)" />
                </Style>
                <Style Selector="Button.nav-item">
                    <Setter Property="Width" Value="42" />
                    <Setter Property="Height" Value="42" />
                    <Setter Property="MinWidth" Value="42" />
                    <Setter Property="MinHeight" Value="42" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,2" />
                    <Setter Property="CornerRadius" Value="6" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
                <Style Selector="Button.nav-item:pointerover">
                    <Setter Property="Background" Value="{DynamicResource SemiGrey1}" />
                </Style>
                <Style Selector="Button.nav-item.selected">
                    <Setter Property="Background" Value="{DynamicResource SemiBlue1}" />
                </Style>
                <Style Selector="Button.nav-item PathIcon">
                    <Setter Property="Foreground" Value="{DynamicResource SemiGrey5}" />
                </Style>
                <Style Selector="Button.nav-item.selected PathIcon">
                    <Setter Property="Foreground" Value="{DynamicResource SemiBlue5}" />
                </Style>
            </Grid.Styles>

            <Border
                IsVisible="{Binding IsMenuVisible}"
                Padding="4 4"
                Grid.RowSpan="2"
                VerticalAlignment="Stretch"
                Theme="{DynamicResource CardBorder}">
                <DockPanel Width="42" LastChildFill="True">
                    <!-- <Grid DockPanel.Dock="Top" HorizontalAlignment="Center" Width="42" Height="42" Margin="0,0,0,8"> -->
                    <!--     <Image -->
                    <!--         VerticalAlignment="Center" -->
                    <!--         HorizontalAlignment="Center" -->
                    <!--         MaxWidth="24" -->
                    <!--         MaxHeight="24" -->
                    <!--         Source="../Assets/Icon.png" /> -->
                    <!-- </Grid> -->

                    <controls:Footer DockPanel.Dock="Bottom" DataContext="{Binding}" />

                    <ItemsControl ItemsSource="{Binding Menus.MenuItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MenuItemViewData">
                                <Button Classes.nav-item="True"
                                        Classes.selected="{Binding IsSelected}"
                                        Command="{Binding ActivateCommand}">
                                    <PathIcon Width="20"
                                              Height="20"
                                              Data="{Binding MenuIconName, Converter={StaticResource IconConverter}}" />
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding MenuHeader}" />
                                    </ToolTip.Tip>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <ContentControl
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,10,5,0"
                Content="{Binding Content}">
                <ContentControl.ContentTemplate>
                    <converters:ViewLocator />
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- <u:ToolBarPanel Grid.Row="1" Grid.Column="1"></u:ToolBarPanel> -->
        </Grid>
        <u:OverlayDialogHost Name="Host" SnapThickness="20" />
    </Panel>

</UserControl>
