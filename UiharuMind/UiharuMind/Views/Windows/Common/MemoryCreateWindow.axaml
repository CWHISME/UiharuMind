<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:common="clr-namespace:UiharuMind.Views.Windows.Common"
        xmlns:loc="clr-namespace:UiharuMind.ViewModels.Markup"
        mc:Ignorable="d"
        x:Class="UiharuMind.Views.Windows.Common.MemoryCreateWindow"
        Width="560"
        Height="420"
        MinWidth="480"
        MinHeight="360"
        Title="{loc:Loc MemoryCreateTitle}">
    <Design.DataContext>
        <common:MemoryCreateWindowModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.muted">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource SemiGrey5}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource SemiGrey0}">
        <Border Padding="18,15" BorderBrush="{DynamicResource SemiGrey2}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="50,*" ColumnSpacing="12">
                <Border Width="50" Height="50" CornerRadius="8"
                        Background="{DynamicResource SemiBlue0}">
                    <PathIcon Width="24" Height="24" Data="{StaticResource BookStarRegular}"
                              Foreground="{DynamicResource SemiBlue5}" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="{loc:Loc MemoryCreateTitle}" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="{loc:Loc MemoryCreateHint}" Classes="muted" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="18" Spacing="16">
            <StackPanel Spacing="6">
                <TextBlock Text="{loc:Loc MemoryNameLabel}" FontWeight="SemiBold" />
                <TextBox Text="{Binding Name}"
                         PlaceholderText="{loc:Loc MemoryNamePlaceholder}" />
                <TextBlock Text="{loc:Loc MemoryNameHint}" Classes="muted" />
                <TextBlock Text="{loc:Loc MemoryNameInvalid}"
                           FontSize="12"
                           Foreground="{DynamicResource MemoryStatusDangerBrush}"
                           IsVisible="{Binding HasNameError}" />
            </StackPanel>
            <StackPanel Spacing="6">
                <TextBlock Text="{loc:Loc MemoryDescriptionLabel}" FontWeight="SemiBold" />
                <TextBox Text="{Binding Description}"
                         MinHeight="110"
                         MaxLength="240"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         Padding="10"
                         PlaceholderText="{loc:Loc MemoryDescriptionPlaceholder}" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Padding="14" BorderBrush="{DynamicResource SemiGrey2}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="{loc:Loc CancelBtn}" Click="CancelButton_Click" />
                <Button IsEnabled="{Binding CanCreate}" Click="CreateButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Width="15" Height="15" Data="{StaticResource DocumentAddRegular}" />
                        <TextBlock Text="{loc:Loc MemoryCreateAction}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
