<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:UiharuMind.Services"
        x:Class="UiharuMind.Views.Windows.Common.ApplicationNotificationWindow"
        Width="380"
        MaxHeight="720"
        SizeToContent="Height">
    <Window.Styles>
        <Style Selector="Border.notification-card">
            <Setter Property="Background" Value="{DynamicResource SemiGrey0}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MessageStatusInfoBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style Selector="Border.notification-card[Tag=Success]">
            <Setter Property="BorderBrush" Value="{DynamicResource MessageStatusSuccessBrush}" />
        </Style>
        <Style Selector="Border.notification-card[Tag=Warning]">
            <Setter Property="BorderBrush" Value="{DynamicResource MessageStatusWarningBrush}" />
        </Style>
        <Style Selector="Border.notification-card[Tag=Error]">
            <Setter Property="BorderBrush" Value="{DynamicResource MessageStatusErrorBrush}" />
        </Style>
        <Style Selector="TextBlock.notification-icon">
            <Setter Property="Foreground" Value="{DynamicResource MessageStatusInfoBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.notification-card[Tag=Success] TextBlock.notification-icon">
            <Setter Property="Foreground" Value="{DynamicResource MessageStatusSuccessBrush}" />
        </Style>
        <Style Selector="Border.notification-card[Tag=Warning] TextBlock.notification-icon">
            <Setter Property="Foreground" Value="{DynamicResource MessageStatusWarningBrush}" />
        </Style>
        <Style Selector="Border.notification-card[Tag=Error] TextBlock.notification-icon">
            <Setter Property="Foreground" Value="{DynamicResource MessageStatusErrorBrush}" />
        </Style>
        <Style Selector="Button.notification-close">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.notification-repeat">
            <Setter Property="Background" Value="{DynamicResource SemiGrey1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SemiGrey3}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <ScrollViewer MaxHeight="720"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="services:ApplicationNotification">
                    <Border Classes="notification-card"
                            Tag="{Binding Severity}"
                            AttachedToVisualTree="Notification_OnAttachedToVisualTree"
                            DetachedFromVisualTree="Notification_OnDetachedFromVisualTree"
                            PointerEntered="Notification_OnPointerEntered"
                            PointerExited="Notification_OnPointerExited">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <TextBlock Classes="notification-icon"
                                       Width="21"
                                       Height="21"
                                       Margin="0,1,0,0"
                                       VerticalAlignment="Top"
                                       Text="{Binding IconText}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SemiGrey7}"
                                               TextWrapping="Wrap" />
                                    <Border Grid.Column="1"
                                            Classes="notification-repeat"
                                            IsVisible="{Binding HasRepeat}">
                                        <TextBlock Text="{Binding RepeatCountText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SemiGrey6}" />
                                    </Border>
                                </Grid>
                                <ScrollViewer MaxHeight="112"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="{DynamicResource SemiGrey6}"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Classes="notification-close"
                                    Content="×"
                                    Command="{Binding CloseCommand}"
                                    ToolTip.Tip="{Binding CloseText}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>
