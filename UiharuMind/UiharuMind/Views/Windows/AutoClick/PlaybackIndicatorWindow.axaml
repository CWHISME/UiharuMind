<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:loc="clr-namespace:UiharuMind.ViewModels.Markup"
    x:Class="UiharuMind.Views.Windows.AutoClick.PlaybackIndicatorWindow"
    Title="{loc:Loc AutoClickPlaybackIndicatorTitle}">

    <Border Name="IndicatorBorder"
            Background="{DynamicResource SemiBlue0}"
            CornerRadius="8"
            BorderBrush="{DynamicResource SemiBlue5}"
            BorderThickness="2"
            Padding="15,10">
        <StackPanel HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Spacing="8">
            <TextBlock Text="{loc:Loc AutoClickPlaybackIndicatorTitle}"
                      FontSize="14"
                      FontWeight="Bold"
                      Foreground="{DynamicResource SemiBlue5}"
                      HorizontalAlignment="Center" />
            <TextBlock Name="RoundText"
                      Text="{loc:Loc AutoClickStatusPlaying}"
                      FontSize="12"
                      Foreground="{DynamicResource SemiBlue5}"
                      HorizontalAlignment="Center" />
            <TextBlock Name="StopShortcutText"
                      FontSize="10"
                      Foreground="{DynamicResource SemiGrey6}"
                      HorizontalAlignment="Center"
                      FontStyle="Italic" />
        </StackPanel>
    </Border>
</Window>
