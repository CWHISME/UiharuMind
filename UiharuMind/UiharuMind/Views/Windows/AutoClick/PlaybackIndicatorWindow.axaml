<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="UiharuMind.Views.Windows.AutoClick.PlaybackIndicatorWindow"
    Title="播放中">
    
    <Border Name="IndicatorBorder" 
            Background="#DBEAFE" 
            CornerRadius="8"
            BorderBrush="#3B82F6"
            BorderThickness="2"
            Padding="15,10">
        <StackPanel HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   Spacing="8">
            <TextBlock Text="▶ 播放中..." 
                      FontSize="14" 
                      FontWeight="Bold"
                      Foreground="#2563EB"
                      HorizontalAlignment="Center" />
            <TextBlock Name="RoundText"
                      Text="执行中..." 
                      FontSize="12"
                      Foreground="#6B7280"
                      HorizontalAlignment="Center" />
            <TextBlock Text="按 Alt+Shift+G 停止"
                      FontSize="10"
                      Foreground="#9CA3AF"
                      HorizontalAlignment="Center"
                      FontStyle="Italic" />
        </StackPanel>
    </Border>
</Window>
