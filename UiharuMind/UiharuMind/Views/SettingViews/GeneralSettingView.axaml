<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settingViews="clr-namespace:UiharuMind.Views.SettingViews"
             xmlns:loc="clr-namespace:UiharuMind.ViewModels.Markup"
             xmlns:common="clr-namespace:UiharuMind.Views.Common"
             xmlns:u="https://irihi.tech/ursa"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UiharuMind.Views.SettingViews.GeneralSettingView">

    <Design.DataContext>
        <settingViews:GeneralSettingViewModel />
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="22" MaxWidth="760">
            <StackPanel Spacing="8">
                <TextBlock Text="{loc:Loc ApplicationUpdate}"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <Border Classes="SettingsSection">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" MinHeight="38">
                            <TextBlock Text="{loc:Loc InstalledVersion}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VersionText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SemiGrey7}" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SemiGrey2}" />
                        <Grid ColumnDefinitions="*,Auto" MinHeight="44">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc CheckAppUpdate}" />
                                <TextBlock Text="{loc:Loc CheckAppUpdateDesc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button Command="{Binding CheckApplicationUpdateCommand}"
                                        IsEnabled="{Binding !IsCheckingForAppUpdate}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Width="14" Height="14" Data="{StaticResource ArrowSyncCircleRegular}" />
                                        <TextBlock Text="{loc:Loc CheckUpdate}" />
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenUpdatePageCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <PathIcon Width="14" Height="14" Data="{StaticResource OpenFolderRegular}" />
                                        <TextBlock Text="{loc:Loc ApplicationUpdateGoTo}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Border Padding="10"
                                CornerRadius="7"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource MessageStatusInfoBrush}"
                                Background="{DynamicResource SemiGrey1}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <PathIcon Width="16"
                                          Height="16"
                                          VerticalAlignment="Top"
                                          Data="{StaticResource ArrowSyncCircleRegular}"
                                          Foreground="{DynamicResource MessageStatusInfoBrush}" />
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="{Binding AppUpdateStatusText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LatestVersionText, StringFormat={}{0}}"
                                               FontSize="12"
                                               Foreground="{DynamicResource SemiGrey6}"
                                               TextWrapping="Wrap" />
                                    <SelectableTextBlock Text="{Binding AppUpdateErrorText}"
                                                         FontSize="12"
                                                         Foreground="{DynamicResource MessageStatusErrorBrush}"
                                                         TextWrapping="Wrap"
                                                         IsVisible="{Binding HasAppUpdateError}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsCheckingForAppUpdate}">
                                    <u:LoadingIcon />
                                    <TextBlock Text="{loc:Loc CheckingForUpdates}"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border IsVisible="{Binding HasAppUpdate}"
                                Padding="10"
                                CornerRadius="7"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource SemiGrey2}"
                                Background="{DynamicResource SemiGrey1}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{loc:Loc ApplicationUpdateDownloadTitle}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc ApplicationUpdateDownloadDesc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}"
                                           TextWrapping="Wrap" />
                                <common:DownloadListView DataContext="{Binding ApplicationUpdateDownloadListViewModel}"
                                                         MaxHeight="150"
                                                         IsVisible="{Binding HasApplicationUpdateAsset}" />
                                <TextBlock Text="{loc:Loc ApplicationUpdateNoAsset}"
                                           FontSize="12"
                                           Foreground="{DynamicResource MessageStatusWarningBrush}"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding !HasApplicationUpdateAsset}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="{loc:Loc UserInterfaceSetting}"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <Border Classes="SettingsSection">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,Auto" MinHeight="44">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc LanguageSetting}" />
                                <TextBlock Text="{loc:Loc LanguageSettingDesc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="220"
                                      ItemsSource="{Binding LanguageOptions}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      VerticalAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SemiGrey2}" />
                        <Grid ColumnDefinitions="*,Auto" MinHeight="44">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc ThemeSetting}" />
                                <TextBlock Text="{loc:Loc ThemeSettingDesc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="160"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme}"
                                      VerticalAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="{loc:Loc GeneralSettings}"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <Border Classes="SettingsSection">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,Auto" MinHeight="44">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc SettingLogLevelTitle}" />
                                <TextBlock Text="{loc:Loc SettingLogLevelDesc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Width="160"
                                      ItemsSource="{Binding LogLevelList}"
                                      SelectedIndex="{Binding LogSelecetedTypeIndex}"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SemiGrey2}" IsVisible="{Binding IsWindows}" />
                        <Grid ColumnDefinitions="*,Auto" MinHeight="52" IsVisible="{Binding IsWindows}">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc FullscreenGameInputSupport}" />
                                <TextBlock Text="{loc:Loc FullscreenGameInputSupportDesc}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding EnableFullscreenGameInputSupport}"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SemiGrey2}" />
                        <Grid ColumnDefinitions="*,Auto" MinHeight="44">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{loc:Loc SaveDirectory}" />
                                <TextBlock Text="{Binding SaveDirectoryPath}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SemiGrey6}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding OpenSaveFolderCommand}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Width="14" Height="14" Data="{StaticResource OpenFolderRegular}" />
                                    <TextBlock Text="{loc:Loc OpenDirectory}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
